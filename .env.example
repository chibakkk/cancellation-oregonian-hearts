# Cancellation Oregonian Hearts
# Copy this file to the environment variable settings of each deployment target.

# Client
# Local development default: http://localhost:3001
# Production example: https://coh-server.example.com
VITE_SERVER_URL=http://localhost:3001

# Server
# Local development default: 3001
PORT=3001

# Browser origins allowed to connect to the HTTP and Socket.IO server.
# Use the deployed client URL in production.
# Local development example: http://localhost:5173
# Production example: https://coh.example.com
CORS_ORIGIN=http://localhost:5173

# Trust X-Forwarded-For for pre-auth rate limits when the server runs behind
# a managed reverse proxy such as Render. Leave false for direct self-hosting.
COH_TRUST_PROXY_HEADERS=false

# State persistence
# If REDIS_URL is set, Redis is used for room state and rate limiting.
# The JSON settings below are ignored for room state when Redis is enabled.
# For local development, leave REDIS_URL empty to use JSON files under server/.data.
REDIS_URL=

# memory: do not persist state across server restarts.
# unset or any other value: use JSON room files unless REDIS_URL is set.
COH_STATE_BACKEND=

# JSON file fallback for local development and simple self-hosting.
COH_STATE_DIR=./.data/rooms
COH_STATE_FILE=./.data/server-state.json

# Expire abandoned rooms and their session tokens.
# Default: 24 hours. Set to 0 to disable expiration.
COH_ROOM_TTL_MS=86400000

# How often the running server scans persisted rooms for expiration.
# Default: 1 hour. Set to 0 to disable the periodic scan.
COH_ROOM_CLEANUP_INTERVAL_MS=3600000

# Redis key namespacing.
COH_REDIS_KEY_PREFIX=coh
COH_REDIS_LOCK_TTL_MS=10000

# Pre-auth room-entry protections. These limit repeated join/resume attempts
# against the same room even if the client reconnects with a new socket.
COH_JOIN_ROOM_ATTEMPT_LIMIT=12
COH_JOIN_ROOM_ATTEMPT_WINDOW_MS=60000
COH_RESUME_SESSION_ATTEMPT_LIMIT=30
COH_RESUME_SESSION_ATTEMPT_WINDOW_MS=60000
